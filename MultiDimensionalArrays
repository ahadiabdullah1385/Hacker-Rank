package week10and11;

public class BMI {
    private String name;
    private int age;
    private double weight; // kilograms
    private double height; // meters

    public BMI(String name, int age, double weight, double height) {
        this.name = name;
        this.age = age;
        this.weight = weight;
        this.height = height;
    }

    public double getBMI() {
        return weight / (height * height);
    }

    public String getStatus() {
        double bmi = getBMI();

        if (bmi < 18.5)
            return "Underweight";
        else if (bmi < 25)
            return "Normal";
        else if (bmi < 30)
            return "Overweight";
        else
            return "Obese";
    }

    public static void main(String[] args) {
        BMI person = new BMI("Bushra", 18, 55, 1.65);

        System.out.println("BMI: " + person.getBMI());
        System.out.println("Status: " + person.getStatus());
