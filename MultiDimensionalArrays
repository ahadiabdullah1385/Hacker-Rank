public class NearestPoints3D {

    public static void main(String[] args) {

        // Given 3D points
        double[][] points = {
            {-1, 0, 3},
            {-1, -1, -1},
            {4, 1, 1},
            {2, 0.5, 9},
            {3.5, 2, -1},
            {3, 1.5, 3},
            {-1.5, 4, 2},
            {5.5, 4, -0.5}
        };

        int p1 = 0;
        int p2 = 1;

        double shortestDistance = distance(points[p1], points[p2]);

        // Find the nearest pair
        for (int i = 0; i < points.length; i++) {
            for (int j = i + 1; j < points.length; j++) {
                double d = distance(points[i], points[j]);

                if (d < shortestDistance) {
                    shortestDistance = d;
                    p1 = i;
                    p2 = j;
                }
            }
        }

        System.out.println("The closest two points are:");
        System.out.println("(" + points[p1][0] + ", " + points[p1][1] + ", " + points[p1][2] + ")");
        System.out.println("(" + points[p2][0] + ", " + points[p2][1] + ", " + points[p2][2] + ")");
        System.out.printf("Distance = %.2f%n", shortestDistance);
    }

    // Method to compute distance between two 3D points
    public static double distance(double[] p1, double[] p2) {
        return Math.sqrt(
                Math.pow(p1[0] - p2[0], 2) +
                Math.pow(p1[1] - p2[1], 2) +
                Math.pow(p1[2] - p2[2], 2)
        );
    }
}
